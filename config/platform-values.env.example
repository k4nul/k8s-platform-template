# Platform values for the selected deployment bundle
# Edit these defaults or generate a filtered file with .\scripts\new-platform-environment.ps1

# Shared Storage
SHARED_STORAGE_NFS_SERVER=nfs.example.internal
SHARED_STORAGE_NFS_PATH=/exports/platform
PLATFORM_STORAGE_CLASS=openebs-hostpath

# Shared Platform
REDIS_PASSWORD=change-me-redis-password
EXTERNAL_DNS_PROVIDER=cloudflare
EXTERNAL_DNS_OWNER_ID=platform-dev
BASE_DOMAIN=example.com

# Applications
NGINX_WEB_MESSAGE=Replace this landing page message with your own text.
NGINX_WEB_HOST=nginx.example.com
HTTPBIN_HOST=httpbin.example.com
WHOAMI_HOST=whoami.example.com
ADMINER_DEFAULT_SERVER=postgresql.platform.svc.cluster.local

# Registry / Optional Platform Add-ons
HARBOR_HOST=harbor.example.com
HARBOR_EXTERNAL_URL=https://harbor.example.com
HARBOR_ADMIN_PASSWORD=change-me-harbor-admin-password
HARBOR_SECRET_KEY=change-me-harbor-secret-key
HARBOR_TLS_SECRET=harbor-tls

# Storage Platform
LONGHORN_HOST=longhorn.example.com
LONGHORN_TLS_SECRET=longhorn-tls
LONGHORN_BASIC_AUTH_SECRET=longhorn-basic-auth

# Cluster Admin
DASHBOARD_HOST=dashboard.example.com
DASHBOARD_TLS_SECRET=dashboard-tls
