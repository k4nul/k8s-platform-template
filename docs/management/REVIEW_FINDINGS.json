{
  "schemaVersion": "1.0.0",
  "kind": "claude_review_findings",
  "projectId": "devops-k8s-platform-template",
  "initializedAt": "2026-06-26",
  "purpose": "Claude Code records review, inspection, and security findings here so Codex can read and resolve them before other implementation work.",
  "workflow": {
    "reviewAgent": "Claude Code",
    "reviewMode": "code_review_inspection_and_security_review",
    "reviewScope": [
      "code_review",
      "code_inspection",
      "security_review"
    ],
    "implementationAgent": "Codex",
    "codexPriorityRule": "Codex must fix or otherwise resolve active Claude Code review and security findings first, ordered by severity, unless the user explicitly overrides that priority."
  },
  "findingSchema": {
    "idFormat": "CR-YYYYMMDD-NNN",
    "categoryValues": [
      "code_review",
      "code_inspection",
      "security_review"
    ],
    "statusValues": [
      "open",
      "in_progress",
      "resolved",
      "wont_fix"
    ],
    "severityValues": [
      "critical",
      "high",
      "medium",
      "low"
    ],
    "requiredFields": [
      "id",
      "status",
      "severity",
      "category",
      "title",
      "location",
      "problem",
      "recommendedFix",
      "createdAt"
    ]
  },
  "activeFindings": [],
  "resolvedFindings": [],
  "lastReview": null
}
