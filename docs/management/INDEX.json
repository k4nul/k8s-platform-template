{
  "schemaVersion": "1.0.0",
  "kind": "management_index",
  "project": {
    "id": "devops-k8s-platform-template",
    "root": "."
  },
  "layout": {
    "instructionDirectory": "docs/management",
    "commonFiles": {
      "managementIndex": "docs/management/INDEX.json",
      "project": "docs/management/PROJECT.json",
      "architecture": "docs/management/ARCHITECTURE.json",
      "plan": "docs/management/PLAN.json",
      "validation": "docs/management/VALIDATION.json",
      "policy": "docs/management/POLICY.json",
      "automation": "docs/management/AUTOMATION.json",
      "reviewFindings": "docs/management/REVIEW_FINDINGS.json"
    },
    "optionalFiles": {
      "legacyInstructions": "docs/management/LEGACY_INSTRUCTIONS.json",
      "benchmarks": "docs/management/BENCHMARKS.json"
    },
    "codexPromptCompatibility": ".codex/"
  },
  "rules": {
    "agentsMdRole": "map_only",
    "instructionFormat": "json_schema_not_prose",
    "commonFilesRequiredForEveryManagedProject": true,
    "projectSpecificFilesAllowed": true,
    "rootDocDirectoryAllowed": false,
    "claudeReviewFindingsRole": "codex_priority_backlog",
    "claudeSecurityFindingsIncluded": true,
    "codexMustReadReviewFindingsBeforeImplementation": true,
    "codexMustReadSecurityFindingsBeforeImplementation": true
  },
  "automationReadiness": {
    "status": "ready",
    "requiresPlan": true,
    "planPath": "docs/management/PLAN.json"
  }
}
